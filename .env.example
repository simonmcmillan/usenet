# Copy to .env and fill in. Do NOT commit .env (it holds secrets).
#   cp .env.example .env

# Run containers as your own user so files aren't owned by root.
# Find yours with: id -u  (PUID) and id -g (PGID)
PUID=1000
PGID=1000

# Your timezone, e.g. Australia/Melbourne, Europe/London, America/New_York
TZ=Australia/Melbourne

# Where service config lives (small, fast SQLite DBs). Put this on an SSD.
# In the default setup this is the repo directory itself.
DATA_ROOT=/home/simon/usenet

# Where the media library + downloads live (the big disk).
# IMPORTANT: downloads and the final library must be on the SAME filesystem
# under here, or hardlinks break and every import doubles disk usage.
MEDIA_ROOT=/var/mnt/storage

# Encryption key for Homarr. Generate your own:
#   openssl rand -hex 32
HOMARR_SECRET=replace-me-with-output-of-openssl-rand-hex-32
